{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/campaign-scheduler",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/campaign-heartbeat",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/recording-backfill",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/stuck-slot-watchdog",
      "schedule": "0 9 * * *"
    }
  ]
}
