<!--
  Voizo dialplan — bridges answered customer leg to Vapi assistant.

  Deploy to /etc/freeswitch/dialplan/default/voizo.xml on the AWS EC2 instance.

  How it's invoked: src/lib/freeswitch/originate.ts issues an `originate` ESL command
  ending with `&transfer(voizo_bridge_to_vapi XML default)`. After the customer
  answers, FS executes this extension on the answered leg.

  Channel variables set by originate-shim:
    voizo_call_id          — Voizo calls_v2.id (for webhook correlation)
    voizo_vapi_assistant   — Vapi assistant ID (for logging)
    voizo_vapi_sip_user    — SIP username for the campaign's Vapi phone number
    voizo_vapi_sip_pass    — SIP digest auth password (shared, from VAPI_SIP_AUTH_PASSWORD env)
    voizo_campaign_id      — for logging
    voizo_number_id        — for logging
    origination_caller_id_number — Caller ID presented to customer

  SIP routing: each campaign gets its own Vapi SIP phone number (Option B).
  The originate-shim resolves the campaign's SIP URI into voizo_vapi_sip_user
  and falls back to "voizo-poc" for campaigns created before multi-agent.
-->
<include>
  <extension name="voizo_bridge_to_vapi">
    <condition field="destination_number" expression="^voizo_bridge_to_vapi$">

      <action application="log" data="INFO Voizo bridge: call_id=${voizo_call_id} assistant=${voizo_vapi_assistant} sip_user=${voizo_vapi_sip_user} campaign=${voizo_campaign_id}"/>

      <action application="set" data="continue_on_fail=true"/>
      <action application="set" data="hangup_after_bridge=true"/>

      <action application="bridge" data="[sip_auth_username=${voizo_vapi_sip_user},sip_auth_password=${voizo_vapi_sip_pass}]sofia/external/sip:${voizo_vapi_sip_user}@sip.vapi.ai"/>

    </condition>
  </extension>
</include>
